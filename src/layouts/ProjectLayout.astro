---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import { Image } from 'astro:assets';

const { title, description, pubDate, heroImage, category, readingTime = "5 mins", sideText, prevPost } = Astro.props;
---

<html lang="id">
    <head>
        <BaseHead title={title} description={description} />
        <style>
            @import "../styles/global.css";
        </style>
    </head>

    <body class="bg-white">
        <Header />
        
        <div id="split-container" class="flex flex-col xl:flex-row min-h-screen relative w-full">
            
            <aside class="w-full xl:w-1/2 relative h-[40vh] xl:h-screen xl:sticky xl:top-0 overflow-hidden bg-slate-900 shrink-0">
                
                <Image 
                    id="parallax-img"
                    src={heroImage}
                    alt="" 
                    class="absolute top-0 left-0 w-full h-full xl:h-[120%] object-cover !rounded-none transition-transform duration-75 ease-out"
                />
                
                <div class="absolute inset-0 bg-black/20 p-8 xl:p-16 flex flex-col justify-end xl:justify-start pointer-events-none">
                    <h2 class="text-white text-5xl xl:text-[7.5rem] font-display font-bold uppercase leading-none tracking-normal break-words max-w-min mt-8 xl:mt-0">
                        {sideText}
                    </h2>
                </div>
            </aside>

            <main class="w-full xl:w-1/2 p-6 xl:p-16 xl:pr-24 flex flex-col">
                <header class="mb-12">
                    <h1 class="text-6xl lg:text-[5rem] font-bold font-display leading-[0.85] tracking-tight text-slate-900 mb-10">
                        {title}
                    </h1>

                    <div class="grid grid-cols-3 gap-4 border-t border-b border-slate-200 py-6 text-[10px] uppercase tracking-widest font-sans font-bold text-slate-400">
                        <div>
                            Publish Date <br />
                            <span class="text-black mt-1 block capitalize font-sans">{
                                new Date(pubDate).toLocaleDateString('id-ID', {
                                weekday: 'long',
                                day: 'numeric',
                                month: 'long',
                                year: 'numeric',
                            })}</span>
                        </div>
                        <div>
                            Category <br />
                            <span class="text-black mt-1 block capitalize font-sans">{category}</span>
                        </div>
                        <div>
                            Reading Time <br />
                            <span class="text-black mt-1 block capitalize font-sans">{readingTime}</span>
                        </div>
                    </div>
                </header>

                <article class="prose prose-xl prose-slate max-w-none mb-20 font-serif">
                    <slot />
                </article>

                <div class="mt-auto pt-10 border-t border-slate-200 flex justify-between text-xs font-bold uppercase tracking-widest font-sans">
    
                    {prevPost ? (
                        <a href={`/blog/${prevPost.id}/`} class="hover:underline">
                            ← Previous: {prevPost.data.title}
                        </a>
                    ) : (
                        <span></span> 
                    )}

                    <a href="#" class="text-slate-300 hover:text-black transition-colors">↑ Back to Top</a>
                </div>
            </main>
        </div>

        <script>
            function initParallax() {
                const container = document.getElementById('split-container');
                const img = document.getElementById('parallax-img');

				
                function onScroll() {
                    if (!container || !img) return;
                    
                    // 1. Ubah batas aktifnya menjadi 1280px (xl) agar sama dengan HTML
                    if (window.innerWidth < 1280) {
                        img.style.transform = 'translateY(0)';
                        return;
                    }

                    const scrollY = window.scrollY;
                    const containerTop = container.offsetTop;

                    // 2. PASTIKAN TIDAK ADA "- 64" DI SINI
                    const viewportHeight = window.innerHeight; 
                    const containerHeight = container.offsetHeight;

                    const maxScroll = containerHeight - viewportHeight;

                    if (maxScroll <= 0) return; 

                    // 3. PASTIKAN TIDAK ADA "+ 64" DI SINI
                    let progress = (scrollY - containerTop) / maxScroll;
                    progress = Math.max(0, Math.min(1, progress)); 

                    const imgHeight = img.offsetHeight;
                    const maxTranslate = viewportHeight - imgHeight;

                    img.style.transform = `translateY(${progress * maxTranslate}px)`;
                }

                // Jalankan fungsi saat pengguna melakukan scroll atau resize layar
                window.addEventListener('scroll', onScroll, { passive: true });
                window.addEventListener('resize', onScroll);

                // Jalankan sekali saat halaman pertama kali dibuka untuk menyesuaikan posisi
                setTimeout(onScroll, 100);
            }

            // Memicu script saat halaman selesai dimuat
            document.addEventListener('DOMContentLoaded', initParallax);
        </script>
    </body>
</html>